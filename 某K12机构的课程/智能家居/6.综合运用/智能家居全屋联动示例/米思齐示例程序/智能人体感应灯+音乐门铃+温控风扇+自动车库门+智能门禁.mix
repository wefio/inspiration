"z/$$)sY;-H.h{Mtf}y0}"><field name="STAT">587</field></shadow></value><next><block type="controls_delay" id="o`=d{jVxy4$T[X[u{zG$"><field name="UNIT">delay</field><value name="DELAY_TIME"><shadow type="math_number" id="Hvd:H4:$5XbY@y*Fs-yt"><field name="NUM">500</field></shadow></value><next><block type="controls_tone" id="rfvqtDx._fSjE7!p0]EM"><value name="PIN"><shadow type="pins_digital" id="N{(KaUBN;.$IQI^e(uGU"><field name="PIN">3</field></shadow></value><value name="FREQUENCY"><shadow type="tone_notes" id="sH7,xAUDrnER|-,~fJE3"><field name="STAT">587</field></shadow></value><next><block type="controls_delay" id="YZClb({*l-Pu/GHDo4q8"><field name="UNIT">delay</field><value name="DELAY_TIME"><shadow type="math_number" id="~+1DtbIfnI0;5pFv8`j*"><field name="NUM">500</field></shadow></value><next><block type="controls_tone" id="=XwV!{QTP2i]I^-Eu[=f"><value name="PIN"><shadow type="pins_digital" id="IeRSu7zs.|(E{uW|v3F^"><field name="PIN">3</field></shadow></value><value name="FREQUENCY"><shadow type="tone_notes" id="(:XsKqYLgqqChW~66Z(U"><field name="STAT">659</field></shadow></value><next><block type="controls_delay" id="c|6N}[,/_lZJ-bufy_Xq"><field name="UNIT">delay</field><value name="DELAY_TIME"><shadow type="math_number" id="E[M:aP;A-j`[o8y(HAbt"><field name="NUM">500</field></shadow></value><next><block type="controls_tone" id="sln@t.Y,vM;S,LqZ0MHn"><value name="PIN"><shadow type="pins_digital" id=")DEw^1^5lWK`paO2,p!X"><field name="PIN">3</field></shadow></value><value name="FREQUENCY"><shadow type="tone_notes" id="Mr8^6~sOePE*Ai?0`x;^"><field name="STAT">784</field></shadow></value><next><block type="controls_delay" id="dLVY@lNkR!S9wht_OKq-"><field name="UNIT">delay</field><value name="DELAY_TIME"><shadow type="math_number" id="SQAkq{,V9CI7*;Y^w:pF"><field name="NUM">500</field></shadow></value><next><block type="controls_tone" id="J@rx1e!{dJJ~g/ff@V=2"><value name="PIN"><shadow type="pins_digital" id="xeLQIwNL0wQ{,.CyQY=5"><field name="PIN">3</field></shadow></value><value name="FREQUENCY"><shadow type="tone_notes" id="A9ac:Bl6:Ur@+iS+u4g6"><field name="STAT">988</field></shadow></value><next><block type="controls_delay" id="g?C5KBG]UD1_N08;S;$,"><field name="UNIT">delay</field><value name="DELAY_TIME"><shadow type="math_number" id="HCNY]gEhqnk2*wlH]rYY"><field name="NUM">500</field></shadow></value><next><block type="controls_tone" id="oX+=7Yz2bs)VUv:=nZ/F"><value name="PIN"><shadow type="pins_digital" id="#rF7,)?HrUY1-n;x4RrL"><field name="PIN">3</field></shadow></value><value name="FREQUENCY"><shadow type="tone_notes" id="UV)ELMQrL@fgIiqe;^k_"><field name="STAT">880</field></shadow></value><next><block type="controls_delay" id="w26/7Sc=^,aihHMKhH8@"><field name="UNIT">delay</field><value name="DELAY_TIME"><shadow type="math_number" id="!nw=l$7!c=dDZ.[PV[pm"><field name="NUM">500</field></shadow></value><next><block type="controls_tone" id="K5eaS:W,sHWF73_[,4Ky"><value name="PIN"><shadow type="pins_digital" id="A/hpTx#/GNZ1Sn?l8x6L"><field name="PIN">3</field></shadow></value><value name="FREQUENCY"><shadow type="tone_notes" id="1[.P*e#4G$`u4jcqJ6@5"><field name="STAT">988</field></shadow></value><next><block type="controls_delay" id="M,x]cL$th(sxicl:EwzH"><field name="UNIT">delay</field><value name="DELAY_TIME"><shadow type="math_number" id="EWcO//{{@C|KR3dyY/-A"><field name="NUM">500</field></shadow></value><next><block type="controls_tone" id="xlukPf3wQ873aHXG`EPq"><value name="PIN"><shadow type="pins_digital" id="y(,(3*JjNKCC!-|WjW+U"><field name="PIN">3</field></shadow></value><value name="FREQUENCY"><shadow type="tone_notes" id="I6Y]:suKoIE8#{ffC7_~"><field name="STAT">988</field></shadow></value><next><block type="controls_delay" id="~~?a:M(5*n1^=ylg}4hQ"><field name="UNIT">delay</field><value name="DELAY_TIME"><shadow type="math_number" id="pm^~CRH{:VTFeKRTdbP]"><field name="NUM">500</field></shadow></value><next><block type="controls_tone" id="_|}TLwRhNR:?TiY,Ur-d"><value name="PIN"><shadow type="pins_digital" id="5;|8LL!tjY56*!6T6oxc"><field name="PIN">3</field></shadow></value><value name="FREQUENCY"><shadow type="tone_notes" id="D^V,~}K}NU(N)2^Pv@P~"><field name="STAT">659</field></shadow></value><next><block type="controls_delay" id="-CF:K@:~U_$}eNEJ#6xl"><field name="UNIT">delay</field><value name="DELAY_TIME"><shadow type="math_number" id="`UVOB!@beYx_PXotIO)N"><field name="NUM">500</field></shadow></value></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></statement></block><block type="procedures_defnoreturn" id="VL$X*S[mC7*rll/ws#{7" x="719" y="34"><field name="NAME">兰花草</field><statement name="STACK"><block type="factory_declare2" id="Vp((L~X]3K+5P{ym~B-S"><field name="VALUE">int BEAT = 500; &amp;#10;#define NOTE_L3 220&amp;#10;#define NOTE_L5 262&amp;#10;#define NOTE_L6 294&amp;#10;#define NOTE_L7 330&amp;#10;#define NOTE_1  349&amp;#10;#define NOTE_2  392&amp;#10;#define NOTE_3  440&amp;#10;#define NOTE_4  466&amp;#10;#define NOTE_5  523&amp;#10;#define NOTE_6  587&amp;#10;int pin = 3; // 蜂鸣器引脚</field><next><block type="factory_block_with_textarea" id="Oj!KE*6eXjVYRO;ofGM6"><field name="VALUE">  // --- 第一段：我从山中来，带来兰花草 ---&amp;#10;  // 6 3 3 3 | 3. 2 | 1. 2 1 7̣ | 6̣ - &amp;#10;  tone(pin, NOTE_6); delay(BEAT*0.5);&amp;#10;  tone(pin, NOTE_3); delay(BEAT*0.5);&amp;#10;  tone(pin, NOTE_3); delay(BEAT*0.5);&amp;#10;  tone(pin, NOTE_3); delay(BEAT*0.5);&amp;#10;&amp;#10;  tone(pin, NOTE_3); delay(BEAT*0.75);&amp;#10;  tone(pin, NOTE_2); delay(BEAT*0.25);&amp;#10;&amp;#10;  tone(pin, NOTE_1); delay(BEAT*0.75);&amp;#10;  tone(pin, NOTE_2); delay(BEAT*0.25);&amp;#10;  tone(pin, NOTE_1); delay(BEAT*0.5);&amp;#10;  tone(pin, NOTE_L7); delay(BEAT*0.5);&amp;#10;&amp;#10;  tone(pin, NOTE_L6); delay(BEAT*2.0);&amp;#10;wdt_reset();&amp;#10;  // --- 第二段：种在小园中，希望花开早 ---&amp;#10;  // 6 6 6 6 | 6. 5 | 3 5 5 #4 | 3 -&amp;#10;  tone(pin, NOTE_6); delay(BEAT*0.5);&amp;#10;  tone(pin, NOTE_6); delay(BEAT*0.5);&amp;#10;  tone(pin, NOTE_6); delay(BEAT*0.5);&amp;#10;  tone(pin, NOTE_6); delay(BEAT*0.5);&amp;#10;&amp;#10;  tone(pin, NOTE_6); delay(BEAT*0.75);&amp;#10;  tone(pin, NOTE_5); delay(BEAT*0.25);&amp;#10;&amp;#10;  tone(pin, NOTE_3); delay(BEAT*0.5);&amp;#10;  tone(pin, NOTE_5); delay(BEAT*0.5);&amp;#10;  tone(pin, NOTE_5); delay(BEAT*0.5);&amp;#10;  tone(pin, NOTE_4); delay(BEAT*0.5); // #4 在F调中接近 466Hz&amp;#10;&amp;#10;  tone(pin, NOTE_3); delay(BEAT*2.0);&amp;#10;wdt_reset();&amp;#10;  // --- 第三段：一日看三回，看得花时过 ---&amp;#10;  // 3 6 6 5 | 3. 2 | 1. 2 1 7̣ | 6̣ 3&amp;#10;  tone(pin, NOTE_3); delay(BEAT*0.5);&amp;#10;  tone(pin, NOTE_6); delay(BEAT*0.5);&amp;#10;  tone(pin, NOTE_6); delay(BEAT*0.5);&amp;#10;  tone(pin, NOTE_5); delay(BEAT*0.5);&amp;#10;&amp;#10;  tone(pin, NOTE_3); delay(BEAT*0.75);&amp;#10;  tone(pin, NOTE_2); delay(BEAT*0.25);&amp;#10;&amp;#10;  tone(pin, NOTE_1); delay(BEAT*0.75);&amp;#10;  tone(pin, NOTE_2); delay(BEAT*0.25);&amp;#10;  tone(pin, NOTE_1); delay(BEAT*0.5);&amp;#10;  tone(pin, NOTE_L7); delay(BEAT*0.5);&amp;#10;&amp;#10;  tone(pin, NOTE_L6); delay(BEAT*1.5);&amp;#10;  tone(pin, NOTE_3); delay(BEAT*0.5);&amp;#10;wdt_reset();&amp;#10;  // --- 第四段：兰花却依然，苞也无一个 ---&amp;#10;  // 3 1 1 7̣ | 6̣ 3 | 2 1 7̣ 5̣ | 6̣ -&amp;#10;  tone(pin, NOTE_3); delay(BEAT*0.5);&amp;#10;  tone(pin, NOTE_1); delay(BEAT*0.5);&amp;#10;  tone(pin, NOTE_1); delay(BEAT*0.5);&amp;#10;  tone(pin, NOTE_L7); delay(BEAT*0.5);&amp;#10;&amp;#10;  tone(pin, NOTE_L6); delay(BEAT*1.5);&amp;#10;  tone(pin, NOTE_3); delay(BEAT*0.5);&amp;#10;&amp;#10;  tone(pin, NOTE_2); delay(BEAT*0.5);&amp;#10;  tone(pin, NOTE_1); delay(BEAT*0.5);&amp;#10;  tone(pin, NOTE_L7); delay(BEAT*0.5);&amp;#10;  tone(pin, NOTE_L5); delay(BEAT*0.5);&amp;#10;&amp;#10;  tone(pin, NOTE_L6); delay(BEAT*2.0);&amp;#10;wdt_reset();&amp;#10;  // --- 结尾间奏 ---&amp;#10;  // (3 1 1 7̣ | 6̣. 3̣ | 2 2 5̣ 7̣ | 6̣ -)&amp;#10;  tone(pin, NOTE_3); delay(BEAT*0.5);&amp;#10;  tone(pin, NOTE_1); delay(BEAT*0.5);&amp;#10;  tone(pin, NOTE_1); delay(BEAT*0.5);&amp;#10;  tone(pin, NOTE_L7); delay(BEAT*0.5);&amp;#10;&amp;#10;  tone(pin, NOTE_L6); delay(BEAT*1.5);&amp;#10;  tone(pin, NOTE_L3); delay(BEAT*0.5); &amp;#10;&amp;#10;  tone(pin, NOTE_2); delay(BEAT*0.5);&amp;#10;  tone(pin, NOTE_2); delay(BEAT*0.5);&amp;#10;  tone(pin, NOTE_L5); delay(BEAT*0.5);&amp;#10;  tone(pin, NOTE_L7); delay(BEAT*0.5);&amp;#10;&amp;#10;  tone(pin, NOTE_L6); delay(BEAT*2.0);&amp;#10;  wdt_reset();&amp;#10;  noTone(pin); // 停止播放</field></block></next></block></statement></block><block type="procedures_defnoreturn" id="3H@Vy!IMbFw}7$z)(mx$" x="1234" y="32"><field name="NAME">我的祖国</field><statement name="STACK"><block type="factory_block_with_textarea" id="3`a|3+s}7JAvt.lGaSkp"><field name="VALUE">// 基础频率定义 (1=F)&amp;#10;#define NOTE_L5 262  // 低音 5&amp;#10;#define NOTE_L6 294  // 低音 6&amp;#10;#define NOTE_L7 330  // 低音 7&amp;#10;#define NOTE_1  349  // 中音 1&amp;#10;#define NOTE_2  392  // 中音 2&amp;#10;#define NOTE_3  440  // 中音 3&amp;#10;#define NOTE_4  466  // 中音 4&amp;#10;#define NOTE_5  523  // 中音 5&amp;#10;#define NOTE_6  587  // 中音 6&amp;#10;#define NOTE_H1 698  // 高音 1&amp;#10;#define NOTE_H2 784  // 高音 2&amp;#10;&amp;#10;int pin = 3;   // 蜂鸣器引脚&amp;#10;int B = 800;   // 基准拍 (1拍) 的时长</field><next><block type="factory_block_with_textarea" id="a!ClFkYS6R?D7{8#@R~["><field name="VALUE">  // --- “一条大河波浪宽” (12 6̣5̣ 5. 6 | 35 i6 5 -) ---&amp;#10;  tone(pin, NOTE_1);  delay(B*0.25); tone(pin, NOTE_2);  delay(B*0.25); &amp;#10;  tone(pin, NOTE_L6); delay(B*0.25); tone(pin, NOTE_L5); delay(B*0.25); &amp;#10;  tone(pin, NOTE_L5); delay(B*0.75); tone(pin, NOTE_L6); delay(B*0.25); &amp;#10;  wdt_reset();&amp;#10;  tone(pin, NOTE_3);  delay(B*0.5);  tone(pin, NOTE_5);  delay(B*0.5); &amp;#10;  tone(pin, NOTE_H1); delay(B*0.5);  tone(pin, NOTE_6);  delay(B*0.5); &amp;#10;  tone(pin, NOTE_5);  delay(B*2.0);&amp;#10;wdt_reset();&amp;#10;  // --- “风吹稻花香两岸” (5 65 32 3 | 53 61 2 -) ---&amp;#10;  tone(pin, NOTE_5);  delay(B*1.0); &amp;#10;  tone(pin, NOTE_6);  delay(B*0.5);  tone(pin, NOTE_5);  delay(B*0.5); &amp;#10;  tone(pin, NOTE_3);  delay(B*0.5);  tone(pin, NOTE_2);  delay(B*0.5); &amp;#10;  tone(pin, NOTE_3);  delay(B*1.0); &amp;#10;  wdt_reset();&amp;#10;  tone(pin, NOTE_5);  delay(B*0.5);  tone(pin, NOTE_3);  delay(B*0.5); &amp;#10;  tone(pin, NOTE_6);  delay(B*0.5);  tone(pin, NOTE_1);  delay(B*0.5); &amp;#10;  tone(pin, NOTE_2);  delay(B*2.0);&amp;#10;wdt_reset();&amp;#10;  // --- “我家就在岸上住” (25 31 6 56 | 26 56 3. 2) ---&amp;#10;  tone(pin, NOTE_2);  delay(B*0.5);  tone(pin, NOTE_5);  delay(B*0.5); &amp;#10;  tone(pin, NOTE_3);  delay(B*0.5);  tone(pin, NOTE_1);  delay(B*0.5); &amp;#10;  tone(pin, NOTE_6);  delay(B*1.0); &amp;#10;  tone(pin, NOTE_5);  delay(B*0.5);  tone(pin, NOTE_6);  delay(B*0.5); &amp;#10;  wdt_reset();&amp;#10;  tone(pin, NOTE_2);  delay(B*0.5);  tone(pin, NOTE_6);  delay(B*0.5); &amp;#10;  tone(pin, NOTE_5);  delay(B*0.5);  tone(pin, NOTE_6);  delay(B*0.5); &amp;#10;  tone(pin, NOTE_3);  delay(B*0.75); tone(pin, NOTE_2);  delay(B*0.25);&amp;#10;wdt_reset();&amp;#10;  // --- “听惯了艄公的号子，看惯了船上的白帆” ---&amp;#10;  // (122 355 i6 5 | 56 12 4. 66 | 56 32 1 -)&amp;#10;  tone(pin, NOTE_1); delay(B*0.33); tone(pin, NOTE_2); delay(B*0.33); tone(pin, NOTE_2); delay(B*0.33); &amp;#10;  tone(pin, NOTE_3); delay(B*0.33); tone(pin, NOTE_5); delay(B*0.33); tone(pin, NOTE_5); delay(B*0.33); &amp;#10;  tone(pin, NOTE_H1); delay(B*0.5); tone(pin, NOTE_6); delay(B*0.5); &amp;#10;  tone(pin, NOTE_5); delay(B*1.0); &amp;#10;wdt_reset();&amp;#10;  tone(pin, NOTE_5); delay(B*0.5); tone(pin, NOTE_6); delay(B*0.5); &amp;#10;  tone(pin, NOTE_1); delay(B*0.5); tone(pin, NOTE_2); delay(B*0.5); &amp;#10;  tone(pin, NOTE_4); delay(B*0.75); tone(pin, NOTE_6); delay(B*0.125); tone(pin, NOTE_6); delay(B*0.125); &amp;#10;wdt_reset();&amp;#10;  tone(pin, NOTE_5); delay(B*0.5); tone(pin, NOTE_6); delay(B*0.5); &amp;#10;  tone(pin, NOTE_3); delay(B*0.5); tone(pin, NOTE_2); delay(B*0.5); &amp;#10;  tone(pin, NOTE_1); delay(B*2.0); &amp;#10;wdt_reset();&amp;#10;  noTone(pin);</field></block></next></block></statement></block><block type="procedures_defnoreturn" id="9EW3/-,]U9m.SOTTzV=h" x="1805" y="8"><field name="NAME">浏阳河</field><statement name="STACK"><block type="factory_block_with_textarea" id="5in3YwcqeB{PIW7d)Vj("><field name="VALUE">// F 调频率表 (1=F)&amp;#10;#define NOTE_L5 262&amp;#10;#define NOTE_L6 294&amp;#10;#define NOTE_1  349&amp;#10;#define NOTE_2  392&amp;#10;#define NOTE_3  440&amp;#10;#define NOTE_5  523&amp;#10;#define NOTE_6  587&amp;#10;#define NOTE_H1 698&amp;#10;#define NOTE_H2 784&amp;#10;#define NOTE_H3 880&amp;#10;#define NOTE_H5 1046&amp;#10;&amp;#10;int pin = 3;&amp;#10;int B = 600; // 中速，一拍设为 600ms</field><next><block type="factory_block_with_textarea" id="Ns;}4Vc{`Em![mclKuKW"><field name="VALUE">  // --- “浏阳河，弯过了几道弯” (5 6 i | 6 5 3 5 | 3 2 (55 6) | 1 1 2 5 5 3) ---&amp;#10;  tone(pin, NOTE_5);  delay(B*0.5); &amp;#10;  tone(pin, NOTE_6);  delay(B*0.5);&amp;#10;  tone(pin, NOTE_H1); delay(B*1.0); &amp;#10;  wdt_reset();&amp;#10;  tone(pin, NOTE_6);  delay(B*0.5);&amp;#10;  tone(pin, NOTE_5);  delay(B*0.25);&amp;#10;  tone(pin, NOTE_3);  delay(B*0.25);&amp;#10;  tone(pin, NOTE_5);  delay(B*1.0);&amp;#10;wdt_reset();&amp;#10;  tone(pin, NOTE_3);  delay(B*0.5);&amp;#10;  tone(pin, NOTE_2);  delay(B*0.5);&amp;#10;  tone(pin, NOTE_L5); delay(B*0.25);&amp;#10;  tone(pin, NOTE_L5); delay(B*0.25);&amp;#10;  tone(pin, NOTE_L6); delay(B*0.5);&amp;#10;wdt_reset();&amp;#10;  tone(pin, NOTE_1);  delay(B*0.33); tone(pin, NOTE_1); delay(B*0.33); tone(pin, NOTE_2); delay(B*0.33); &amp;#10;  tone(pin, NOTE_5);  delay(B*0.5);  tone(pin, NOTE_5); delay(B*0.25); tone(pin, NOTE_3); delay(B*0.25);&amp;#10;wdt_reset();&amp;#10;  // --- “几十里水路到湘江” (2 1 (6 5) | 5 3 5 6 i 6 5 | 3. 5 3 | 2 3 2 1 | 6. 1 5 6 | 1) ---&amp;#10;  tone(pin, NOTE_2);  delay(B*0.5);&amp;#10;  tone(pin, NOTE_1);  delay(B*0.5);&amp;#10;  tone(pin, NOTE_L6); delay(B*0.5); // 间奏小音符&amp;#10;  tone(pin, NOTE_L5); delay(B*0.5);&amp;#10;wdt_reset();&amp;#10;  tone(pin, NOTE_5);  delay(B*0.25); tone(pin, NOTE_3); delay(B*0.25);&amp;#10;  tone(pin, NOTE_5);  delay(B*0.25); tone(pin, NOTE_6); delay(B*0.25);&amp;#10;  tone(pin, NOTE_H1); delay(B*0.25); tone(pin, NOTE_6); delay(B*0.25);&amp;#10;  tone(pin, NOTE_5);  delay(B*0.5);&amp;#10;wdt_reset();&amp;#10;  tone(pin, NOTE_3);  delay(B*0.75); tone(pin, NOTE_5); delay(B*0.25);&amp;#10;  tone(pin, NOTE_3);  delay(B*1.0);&amp;#10;wdt_reset();&amp;#10;  tone(pin, NOTE_2);  delay(B*0.33); tone(pin, NOTE_3); delay(B*0.33); tone(pin, NOTE_2); delay(B*0.33);&amp;#10;  tone(pin, NOTE_1);  delay(B*1.0);&amp;#10;wdt_reset();&amp;#10;  tone(pin, NOTE_L6); delay(B*0.75); tone(pin, NOTE_1); delay(B*0.25);&amp;#10;  tone(pin, NOTE_L5); delay(B*0.5);&amp;#10;  tone(pin, NOTE_L6); delay(B*0.5);&amp;#10;wdt_reset();&amp;#10;  tone(pin, NOTE_1);  delay(B*2.0); // 结束长音&amp;#10;wdt_reset();&amp;#10;  // --- “江边有个什么县哪” ---&amp;#10;  tone(pin, NOTE_1);  delay(B*0.5);&amp;#10;  tone(pin, NOTE_1);  delay(B*0.25); tone(pin, NOTE_2); delay(B*0.25);&amp;#10;  tone(pin, NOTE_3);  delay(B*1.0);&amp;#10;wdt_reset();&amp;#10;  tone(pin, NOTE_5);  delay(B*0.5);&amp;#10;  tone(pin, NOTE_5);  delay(B*0.25); tone(pin, NOTE_3); delay(B*0.25);&amp;#10;  wdt_reset();&amp;#10;  tone(pin, NOTE_2);  delay(B*0.25); tone(pin, NOTE_3); delay(B*0.25);&amp;#10;  tone(pin, NOTE_2);  delay(B*0.25); tone(pin, NOTE_1); delay(B*0.25);&amp;#10;  tone(pin, NOTE_L6); delay(B*0.5);  tone(pin, NOTE_5);  delay(B*0.5);&amp;#10;wdt_reset();&amp;#10;  // --- “出了个什么人” ---&amp;#10;  tone(pin, NOTE_H1); delay(B*0.5);&amp;#10;  tone(pin, NOTE_H1); delay(B*0.25); tone(pin, NOTE_6); delay(B*0.25);&amp;#10;  tone(pin, NOTE_5);  delay(B*0.5);&amp;#10;  tone(pin, NOTE_H1); delay(B*0.5);&amp;#10;  tone(pin, NOTE_6);  delay(B*0.75); tone(pin, NOTE_5); delay(B*0.25);&amp;#10;wdt_reset();&amp;#10;  // --- “领导我们得解放” ---&amp;#10;  tone(pin, NOTE_1);  delay(B*0.33); tone(pin, NOTE_1); delay(B*0.33); tone(pin, NOTE_1); delay(B*0.33);&amp;#10;  tone(pin, NOTE_2);  delay(B*1.0);&amp;#10;  tone(pin, NOTE_5);  delay(B*0.33); tone(pin, NOTE_5); delay(B*0.33); tone(pin, NOTE_3); delay(B*0.33);&amp;#10;  tone(pin, NOTE_2);  delay(B*0.75); tone(pin, NOTE_3); delay(B*0.25);&amp;#10;wdt_reset();&amp;#10;  // --- “咿呀咿子哟” (结尾) ---&amp;#10;  tone(pin, NOTE_1);  delay(B*0.25);&amp;#10;  tone(pin, NOTE_2);  delay(B*0.25);&amp;#10;  tone(pin, NOTE_1);  delay(B*0.25);&amp;#10;  tone(pin, NOTE_L6); delay(B*0.25);&amp;#10;  tone(pin, NOTE_5);  delay(B*2.0);&amp;#10;wdt_reset();&amp;#10;  noTone(pin);</field></block></next></block></statement></block><block type="procedures_defnoreturn" id="eW+gs4.Z8~?$4KEecG2Y" x="169" y="1069"><field name="NAME">音乐门铃</field><statement name="STACK"><block type="controls_if" id="(p,j)-?qR9vK3k95iagk"><mutation else="1"></mutation><value name="IF0"><block type="logic_compare" id="qlwbGrgv*=LK8Ew_];sC"><field name="OP">EQ</field><value name="A"><block type="inout_digital_read2" id="zNt0i99eCZX/:Q~lx`u["><value name="PIN"><shadow type="pins_digital" id="+)1n^;B[H{)A1u)np`ek"><field name="PIN">2</field></shadow></value></block></value><value name="B"><block type="math_number" id="K0du:R/zjvb}WTghkR)j"><field name="NUM">0</field></block></value></block></value><statement name="DO0"><block type="procedures_callnoreturn" id="ou^_]@wm$b-oGCY{y)gb" disabled-reasons="MANUALLY_DISABLED"><mutation name="浏阳河"></mutation><next><block type="procedures_callnoreturn" id="lWQ7o$lT]h1^V=7RBA(k"><mutation name="我的祖国"></mutation><next><block type="procedures_callnoreturn" id="Km_p4O3YAk(V+#Oe0a7b" disabled-reasons="MANUALLY_DISABLED"><mutation name="兰花草"></mutation><next><block type="procedures_callnoreturn" id=":$[-/B@zsfSA|:e@BPt." disabled-reasons="MANUALLY_DISABLED"><mutation name="茉莉花"></mutation><next><block type="procedures_callnoreturn" id="-)YU?UaWG5eB1H@nck.:" disabled-reasons="MANUALLY_DISABLED"><mutation name="门铃"></mutation></block></next></block></next></block></next></block></next></block></statement><statement name="ELSE"><block type="controls_notone" id="JAff0RgNq~(:1,$XUR2/"><value name="PIN"><shadow type="pins_digital" id=",}y:l+ZY*FxCgvbuTK!)"><field name="PIN">3</field></shadow></value></block></statement></block></statement></block><block type="factory_declare2" id="455/}6aSVbZ$!_I)j8Re" x="4375" y="4303"><field name="VALUE">//完成于2026.2.26;</field></block></xml><config>{}</config><code></code>