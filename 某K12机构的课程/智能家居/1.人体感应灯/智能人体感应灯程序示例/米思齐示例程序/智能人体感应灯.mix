<xml version="Mixly 2.0 rc4" board="Arduino AVR@Arduino/Genuino Uno"><block type="controls_if" id="kdT9(3zUNi,sIWLdey4[" x="382" y="208"><mutation else="1"></mutation><value name="IF0"><block type="logic_compare" id="atvb68`W)pio;:|5b66T"><field name="OP">EQ</field><value name="A"><block type="inout_digital_read2" id=".7fXcp?^41h@XYJ3i,EK"><comment pinned="true" h="98" w="162">判断连接在D4号管脚的人体传感器是否感应到有人靠近，感应到则为1，否则为0.</comment><value name="PIN"><shadow type="pins_digital" id="eL)QTOa*!Rkj*!w067bI"><field name="PIN">4</field></shadow></value></block></value><value name="B"><block type="math_number" id="1m~DyA;OgbX?+~~VQ+bU"><field name="NUM">1</field></block></value></block></value><statement name="DO0"><block type="inout_digital_write2" id="dApn+5JI8=KJ=Y$hJQ1K"><comment pinned="true" h="75" w="165">“高”表示点亮连接在D9号管脚绿灯，时间延续5s</comment><value name="PIN"><shadow type="pins_digital" id="{eGY1CfEvsREaQJS?Zk;"><field name="PIN">9</field></shadow></value><value name="STAT"><shadow type="inout_highlow" id="n=g0V^=8q{TnIY#PP4CX"><field name="BOOL">HIGH</field></shadow></value><next><block type="controls_delay" id="v(|qjre3_;(frk1oVsu}"><field name="UNIT">delay</field><value name="DELAY_TIME"><shadow type="math_number" id="tJ8v:HopsAVco6p_lh-p"><field name="NUM">5000</field></shadow></value></block></next></block></statement><statement name="ELSE"><block type="inout_digital_write2" id="`XA!UpVI`t(Bx,~NUEZ~"><comment pinned="true" h="54" w="167">“低”表示熄灭连接在D9号管脚绿灯</comment><value name="PIN"><shadow type="pins_digital" id=")WrYo0fPhQ+fW~~7JR!e"><field name="PIN">9</field></shadow></value><value name="STAT"><shadow type="inout_highlow" id="nWi7SaOoyowmGUB#*tTG"><field name="BOOL">LOW</field></shadow></value></block></statement></block></xml><config>{}</config><code></code>